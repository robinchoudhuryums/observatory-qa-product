# AssemblyAI API key (required for audio transcription and analysis)
# Get your key at: https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_api_key_here

# Session secret for cookie signing (generate a random string)
# REQUIRED in production — sessions won't persist across restarts without this
SESSION_SECRET=your_random_secret_here

# ─── Storage Backend ──────────────────────────────────────────────────
# Set STORAGE_BACKEND to choose explicitly, or leave unset for auto-detection.
#
# STORAGE_BACKEND=postgres  (PostgreSQL — recommended for multi-tenant SaaS)
# STORAGE_BACKEND=s3        (AWS S3 — HIPAA-eligible with BAA)
# (none)                    → auto-detect S3, else in-memory (dev only)

# --- Option 1: PostgreSQL (recommended for SaaS) ---
# Stores all structured data in PostgreSQL. Audio files still go to S3.
# DATABASE_URL=postgresql://user:password@host:5432/observatory
# S3_BUCKET=observatory-audio  (optional: for audio blob storage alongside PG)

# --- Option 2: AWS S3 (original, single-tenant) ---
# S3_BUCKET=ums-call-archive
# Uses AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION from Bedrock section below.

# ─── Redis (sessions, rate limiting, job queues) ──────────────────────
# Required for production multi-tenant SaaS. Without it, falls back to
# in-memory sessions/rate-limiting (non-persistent, single-instance only).
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:password@host:6380  (TLS in production)

# ─── AI Analysis (AWS Bedrock + Claude) ──────────────────────────────
# Controls the AI backend that analyzes call transcripts.
# Per-org override: set bedrockModel in org settings.
#
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# ─── Authentication ───────────────────────────────────────────────────
# Env-var-based users (backward compatible). For SaaS, migrate to DB-backed users.
# Format: username:password:role:displayName:orgSlug (comma-separated)
# Roles: admin, manager, viewer
AUTH_USERS=admin:YourSecurePassword:admin:Admin User:default

# Default org slug for users without an explicit org assignment
# DEFAULT_ORG_SLUG=default

# ─── Betterstack (log aggregation) ───────────────────────────────────
# Streams structured logs to Betterstack via @logtail/pino transport.
# Without this, logs go to stdout only (still visible in Render logs).
# BETTERSTACK_SOURCE_TOKEN=your_source_token_here

# ─── Email (SMTP) ────────────────────────────────────────────────────
# Required for password reset and invitation emails. Without these,
# emails are logged to console only (dev mode).
# SMTP_HOST=smtp.example.com       # SMTP server (or email-smtp.<region>.amazonaws.com for SES)
# SMTP_PORT=587                    # SMTP port (587 for STARTTLS, 465 for SSL)
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@yourdomain.com # From address
# APP_BASE_URL=https://app.yourdomain.com  # Base URL for email links (password reset, invitations)

# ─── Optional ─────────────────────────────────────────────────────────
# PORT=5000                      # Server port (default: 5000)
# RETENTION_DAYS=90              # Auto-purge calls older than N days (default: 90)
# LOG_LEVEL=info                 # Pino log level: debug, info, warn, error
# WEBHOOK_URL=                   # Slack/Teams webhook for flagged call notifications
# WEBHOOK_COACHING_URL=          # Optional separate channel for coaching alerts
# WEBHOOK_DIGEST_URL=            # Optional separate channel for weekly digests
# WEBHOOK_PLATFORM=slack         # "slack" (default) or "teams"
