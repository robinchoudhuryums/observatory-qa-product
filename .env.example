# AssemblyAI API key (required for audio transcription and analysis)
# Get your key at: https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_api_key_here

# Session secret for cookie signing (generate a random string)
# If not set, a random secret is generated on each startup (sessions won't persist across restarts)
SESSION_SECRET=your_random_secret_here

# Google Cloud Storage bucket name
GCS_BUCKET=ums-call-archive

# GCS Authentication (set ONE of the following):
# Option 1: Path to service account key JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Option 2: Inline service account key JSON (useful for cloud deployments)
# GCS_CREDENTIALS={"client_email":"...","private_key":"...","project_id":"..."}

# User authentication via environment variables
# Format: username:password:role:displayName (comma-separated for multiple users)
# Roles: admin, manager, viewer
AUTH_USERS=admin:YourSecurePassword:admin:Admin User
